    "postinstall": "npm install @prisma/client"
  },
  "prisma": {
    "schema": "../prisma/schema.prisma"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=9"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.956.0",
