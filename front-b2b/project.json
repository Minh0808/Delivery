{
  "name": "front-b2b",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "front-b2b/src",
  "tags": [
    "type:app",
    "scope:b2b"
  ],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/front-b2b",
        "browser": "front-b2b/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "front-b2b/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "front-b2b/public"
          },
          {
            "glob": "**/*",
            "input": "front-b2b/src/assets",
            "output": "assets"
          }
        ],
        "styles": [
          "front-b2b/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "front-b2b:build:production",
          "proxyConfig": "front-b2b/proxy.conf.json"
        },
        "development": {
          "buildTarget": "front-b2b:build:development",
          "proxyConfig": "front-b2b/proxy.conf.json"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "front-b2b:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../coverage/front-b2b"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "front-b2b:build",
        "port": 4200,
        "staticFilePath": "dist/front-b2b/browser",
        "spa": true
      }
    }
  }
}
