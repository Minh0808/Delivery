// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  externalId    String    @unique @default(uuid()) @map("external_id") @db.Uuid // UUID for public exposure
  email         String    @unique
  phone         String?
  username      String?
  passwordHash  String    @map("password_hash")
  profile       Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  lastSeenAt    DateTime? @map("last_seen_at")

  // Relations
  merchantUsers MerchantUser[]
  userRoles     UserRole[]
  carts         Cart[]
  courier       Courier?
  orders        Order[]
  reviews       Review[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., 'merchant_admin'
  scope       RoleScope // Enum: PLATFORM, MERCHANT
  description String?
  
  // Relations
  permissions RolePermission[] // Thay vì Json
  userRoles   UserRole[]
  
  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  resource    String   // e.g., 'product', 'order'
  action      String   // e.g., 'create', 'read', 'delete'
  description String?
  
  // Relations
  roles       RolePermission[]

  @@unique([resource, action]) // Đảm bảo không trùng
  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum RoleScope {
  PLATFORM
  MERCHANT
}

model Merchant {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique @default(uuid()) @map("external_id") @db.Uuid
  name        String
  brandId     Int?     @map("brand_id")
  address     String?  @db.Text
  latitude    Float?
  longitude   Float?
  phone       String?
  status      String?  // 'active' | 'inactive' | 'suspended'
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  brand        Brand?         @relation(fields: [brandId], references: [id])
  merchantUsers MerchantUser[]
  products     Product[]
  menus        Menu[]
  carts        Cart[]
  promotions   Promotion[]
  shippingFees ShippingFee[]
  orders       Order[]
  reviews      Review[]
  userRoles    UserRole[]

  @@map("merchants")
}

model MerchantUser {
  id         Int      @id @default(autoincrement())
  merchantId Int      @map("merchant_id")
  userId     Int      @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("merchant_users")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  merchantId Int?    @map("merchant_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  role     Role      @relation(fields: [roleId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@unique([userId, roleId, merchantId])
  @@map("user_roles")
}

model Brand {
  id          Int     @id @default(autoincrement())
  name        String?
  slug        String? @unique
  description String? @db.Text
  metadata    Json?

  // Relations
  merchants  Merchant[]
  categories Category[] 

  @@map("brands")
}

model Category {
  id       Int     @id @default(autoincrement())
  name     String?
  parentId Int?    @map("parent_id")
  slug     String?

  // Relations
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  
  productCategories ProductCategory[]
  
  brandId Int? @map("brand_id")
  brand   Brand? @relation(fields: [brandId], references: [id])

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique @default(uuid()) @map("external_id") @db.Uuid
  merchantId  Int      @map("merchant_id")
  name        String
  description String?  @db.Text
  price       Decimal? @db.Decimal(12, 2)
  currency    String?  @default("VND")
  sku         String?
  stock       Int?
  isActive    Boolean? @default(true) @map("is_active")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  merchant          Merchant          @relation(fields: [merchantId], references: [id])
  productCategories ProductCategory[]
  variants          ProductVariant[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           Review[]

  @@map("products")
}

model ProductCategory {
  productId  Int @map("product_id")
  categoryId Int @map("category_id")

  // Relations
  product  Product  @relation(fields: [productId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  name      String?
  price     Decimal? @db.Decimal(12, 2)
  stock     Int?
  metadata  Json?

  // Relations
  product Product @relation(fields: [productId], references: [id])

  @@map("product_variants")
}

model Menu {
  id          Int     @id @default(autoincrement())
  merchantId  Int     @map("merchant_id")
  name        String?
  description String? @db.Text

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@map("menus")
}

model Cart {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  merchantId  Int      @map("merchant_id")
  totalAmount Decimal? @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id])
  merchant  Merchant   @relation(fields: [merchantId], references: [id])
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int      @map("cart_id")
  productId Int      @map("product_id")
  variantId Int?     @map("variant_id")
  quantity  Int?
  price     Decimal? @db.Decimal(12, 2)
  total     Decimal? @db.Decimal(12, 2)
  metadata  Json?

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Courier {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  name            String?
  phone           String?
  status          String?  // 'available' | 'busy' | 'offline'
  vehicleType     String?  @map("vehicle_type") // 'bike' | 'motorbike' | 'car'
  currentLocation Json?    @map("current_location")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("couriers")
}

model Promotion {
  id             Int       @id @default(autoincrement())
  merchantId     Int?      @map("merchant_id")
  code           String?
  description    String?   @db.Text
  discountType   String?   @map("discount_type") // 'percentage' | 'fixed'
  discountValue  Decimal?  @map("discount_value") @db.Decimal(12, 2)
  minOrderAmount Decimal?  @map("min_order_amount") @db.Decimal(12, 2)
  startAt        DateTime? @map("start_at")
  endAt          DateTime? @map("end_at")
  maxUses        Int?      @map("max_uses")
  metadata       Json?

  // Relations
  merchant Merchant? @relation(fields: [merchantId], references: [id])
  orders   Order[]

  @@map("promotions")
}

model ShippingFee {
  id          Int      @id @default(autoincrement())
  merchantId  Int      @map("merchant_id")
  minDistance Decimal? @map("min_distance")
  maxDistance Decimal? @map("max_distance")
  baseFee     Decimal? @map("base_fee") @db.Decimal(12, 2)
  feePerKm    Decimal? @map("fee_per_km") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@map("shipping_fees")
}

model Order {
  id              Int      @id @default(autoincrement())
  externalId      String   @unique @default(uuid()) @map("external_id") @db.Uuid
  userId          Int      @map("user_id")
  merchantId      Int      @map("merchant_id")
  totalAmount     Decimal? @map("total_amount") @db.Decimal(12, 2)
  currency        String?  @default("VND")
  status          String?  // 'pending' | 'confirmed' | 'preparing' | 'delivering' | 'completed' | 'cancelled'
  paymentStatus   String?  @map("payment_status") // 'pending' | 'paid' | 'failed' | 'refunded'
  deliveryAddress Json?    @map("delivery_address")
  courierId       Int?     @map("courier_id")
  shippingFee     Decimal? @map("shipping_fee")
  promotionId     Int?     @map("promotion_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id])
  merchant  Merchant   @relation(fields: [merchantId], references: [id])
  courier   Courier?   @relation(fields: [courierId], references: [id])
  promotion Promotion? @relation(fields: [promotionId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  productId Int      @map("product_id")
  variantId Int?     @map("variant_id")
  quantity  Int?
  price     Decimal? @db.Decimal(12, 2)
  total     Decimal? @db.Decimal(12, 2)
  metadata  Json?

  // Relations
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  productId  Int?     @map("product_id")
  merchantId Int?     @map("merchant_id")
  rating     Decimal?
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@map("reviews")
}
