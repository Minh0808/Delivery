// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- CORE IDENTITY & ACCESS MANAGEMENT ---

model User {
  id            Int       @id @default(autoincrement())
  externalId    String    @unique @default(uuid()) @map("external_id") @db.Uuid
  email         String    @unique
  phone         String?
  username      String?
  passwordHash  String?   @map("password_hash") // Optional for OAuth-only users
  hashedRefreshToken String? @map("hashed_refresh_token")
  profile       Json?
  avatarUrl     String?   @map("avatar_url") // Profile picture from OAuth
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  lastSeenAt    DateTime? @map("last_seen_at")

  // Relations
  userRoles     UserRole[]
  ownedAgencies Agency[]  @relation("AgencyOwner")
  ownedMerchants Merchant[] @relation("MerchantOwner")
  carts         Cart[]
  courier       Courier?
  orders        Order[]
  reviews       Review[]
  linkedAccounts LinkedAccount[] // OAuth linked accounts

  @@map("users")
}

// OAuth Linked Accounts (Google, Facebook, etc.)
model LinkedAccount {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  provider      AuthProvider
  providerId    String    @map("provider_id") // Google ID, Facebook ID, etc.
  email         String?   // Email from OAuth provider
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  accessToken   String?   @map("access_token") @db.Text // Store encrypted if needed
  refreshToken  String?   @map("refresh_token") @db.Text
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId]) // Each provider account can only link once
  @@unique([userId, provider]) // Each user can only have one account per provider
  @@map("linked_accounts")
}

enum AuthProvider {
  GOOGLE
  FACEBOOK
  APPLE
  KAKAO // Korean social login
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., 'merchant_admin'
  scope       RoleScope // Enum: PLATFORM, MERCHANT
  description Json?
  
  // Relations
  permissions RolePermission[]
  userRoles   UserRole[]
  
  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  resource    String   // e.g., 'product', 'order'
  action      String   // e.g., 'create', 'read', 'delete'
  description Json?
  
  // Relations
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  description  Json?
  
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

enum RoleScope {
  PLATFORM
  MERCHANT
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  
  // Scopes
  merchantId Int?    @map("merchant_id")
  agencyId   Int?    @map("agency_id")
  brandId    Int?    @map("brand_id")
  
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  role     Role      @relation(fields: [roleId], references: [id])
  
  merchant Merchant? @relation(fields: [merchantId], references: [id])
  agency   Agency?   @relation(fields: [agencyId], references: [id])
  brand    Brand?    @relation(fields: [brandId], references: [id])

  @@unique([userId, roleId, merchantId, agencyId, brandId])
  @@map("user_roles")
}

model Agency {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique @default(uuid()) @map("external_id") @db.Uuid
  name        String
  taxCode     String?  @map("tax_code")
  bankAccount String?  @map("bank_account")
  
  // Contact Info
  address     String?  @db.Text
  phone       String?
  email       String?
  logo        String?
  businessLicenseUrl String? @map("business_license_url")
  
  // Approval Status (one-time, for registration process)
  approvalStatus    ApprovalStatus    @default(PENDING) @map("approval_status")
  approvedAt        DateTime?         @map("approved_at")
  approvedBy        Int?              @map("approved_by")
  rejectedAt        DateTime?         @map("rejected_at")
  rejectedBy        Int?              @map("rejected_by")
  rejectionReason   String?           @map("rejection_reason") @db.Text
  
  // Operational Status (ongoing, can change multiple times)
  operationalStatus OperationalStatus @default(ACTIVE) @map("operational_status")
  statusChangedAt   DateTime?         @map("status_changed_at")
  statusChangedBy   Int?              @map("status_changed_by")
  statusReason      String?           @map("status_reason") @db.Text

  // Ownership
  ownerId     Int?     @map("owner_id")
  owner       User?    @relation("AgencyOwner", fields: [ownerId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  
  brands      Brand[]
  merchants   Merchant[]
  userRoles   UserRole[]

  @@map("agencies")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OperationalStatus {
  ACTIVE      
  INACTIVE    
  SUSPENDED   
  LOCKED      
}

model Brand {
  id          Int     @id @default(autoincrement())
  externalId  String  @unique @default(uuid()) @map("external_id") @db.Uuid
  name        String?
  slug        String? @unique
  description Json?
  metadata    Json?
  businessCategory String? @map("business_category") // Lĩnh vực kinh doanh (VD: F&B, Retail...)
  
  agencyId    Int?    @map("agency_id")

  // Relations
  agency     Agency?  @relation(fields: [agencyId], references: [id])
  merchants  Merchant[]
  categories BrandCategory[] 
  userRoles  UserRole[] 

  @@map("brands")
}

model Category {
  id       Int     @id @default(autoincrement())
  externalId String @unique @default(uuid()) @map("external_id") @db.Uuid
  name     Json?
  parentId Int?    @map("parent_id")
  slug     String?

  // Relations
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  
  brands   BrandCategory[]
  merchants MerchantCategory[]

  @@map("categories")
}

model BrandCategory {
  brandId     Int      @map("brand_id")
  categoryId  Int      @map("category_id")
  
  isFeatured  Boolean  @default(false) @map("is_featured")
  displayOrder Int     @default(0) @map("display_order")

  brand       Brand    @relation(fields: [brandId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  @@id([brandId, categoryId])
  @@map("brand_categories")
}

model Tag {
  id          Int      @id @default(autoincrement())
  code        String   @unique // e.g., 'PREMIUM', 'PARTNER'
  name        Json
  icon        String?
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  
  merchants   MerchantTag[]

  @@map("tags")
}

model MerchantTag {
  merchantId  Int      @map("merchant_id")
  tagId       Int      @map("tag_id")
  description Json?
  
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  tag         Tag      @relation(fields: [tagId], references: [id])

  @@id([merchantId, tagId])
  @@map("merchant_tags")
}

model Merchant {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique @default(uuid()) @map("external_id") @db.Uuid
  name        String
  
  // Ownership & Branding
  brandId     Int?     @map("brand_id")
  agencyId    Int?     @map("agency_id")
  ownerId     Int?     @map("owner_id")
  
  address     String?  @db.Text
  city        String?  // Tên thành phố
  contactName String?  @map("contact_name") // contact name
  businessType String? @map("business_type") // ONLINE, OFFLINE, HYBRID
  businessCategory String? @map("business_category") // Business items (F&B, Grocery, etc.)
  referralSource String? @map("referral_source") // Reasons to know the app
  hasBusinessLicense Boolean? @default(false) @map("has_business_license") // With or without business license
  
  latitude    Float?
  longitude   Float?
  phone       String?
  logoUrl     String?  @map("logo_url") @db.Text
  
  // Approval Status (one-time, for registration process)
  approvalStatus    ApprovalStatus    @default(PENDING) @map("approval_status")
  approvedAt        DateTime?         @map("approved_at")
  approvedBy        Int?              @map("approved_by")
  rejectedAt        DateTime?         @map("rejected_at")
  rejectedBy        Int?              @map("rejected_by")
  rejectionReason   String?           @map("rejection_reason") @db.Text
  
  // Operational Status (ongoing, can change multiple times)
  operationalStatus OperationalStatus @default(ACTIVE) @map("operational_status")
  statusChangedAt   DateTime?         @map("status_changed_at")
  statusChangedBy   Int?              @map("status_changed_by")
  statusReason      String?           @map("status_reason") @db.Text
  
  isAcceptingOrders Boolean @default(true) @map("is_accepting_orders") 
  metadata    Json?
  
  // Denormalized rating stats (updated via service when reviews change)
  averageRating   Float     @default(0) @map("average_rating")
  totalReviews    Int       @default(0) @map("total_reviews")
  ratingBreakdown Json?     @map("rating_breakdown") // {"5": 100, "4": 50, "3": 20, "2": 5, "1": 2}
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  brand        Brand?         @relation(fields: [brandId], references: [id])
  agency       Agency?        @relation(fields: [agencyId], references: [id])
  owner        User?          @relation("MerchantOwner", fields: [ownerId], references: [id])
  
  tags         MerchantTag[]
  products     Product[]
  menus        Menu[]
  carts        Cart[]
  promotions   Promotion[]
  shippingFees ShippingFee[]
  orders       Order[]
  reviews      Review[]
  userRoles    UserRole[]
  operatingHours OperatingHour[]
  categories     MerchantCategory[]

  @@map("merchants")
}

model MerchantCategory {
  merchantId  Int      @map("merchant_id")
  categoryId  Int      @map("category_id")
  
  isFeatured  Boolean  @default(false) @map("is_featured")
  displayOrder Int     @default(0) @map("display_order")

  merchant    Merchant @relation(fields: [merchantId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  @@id([merchantId, categoryId])
  @@map("merchant_categories")
}

model OperatingHour {
  id         Int      @id @default(autoincrement())
  merchantId Int      @map("merchant_id")
  
  // 0: Sunday, 1: Monday, ..., 6: Saturday
  dayOfWeek  Int      @map("day_of_week") 
  
  // Format: "HH:mm" (e.g., "08:00", "22:00")
  openTime   String   @map("open_time")   
  closeTime  String   @map("close_time")

  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("operating_hours")
}

// --- PRODUCT & MENU ---

model Menu {
  id          Int     @id @default(autoincrement())
  merchantId  Int     @map("merchant_id")
  name        Json? // e.g. "Main Menu", "Lunch Menu"
  isActive    Boolean @default(true) @map("is_active")
  description Json?

  // Relations
  merchant Merchant      @relation(fields: [merchantId], references: [id])
  sections MenuSection[]

  @@map("menus")
}

model MenuSection {
  id           Int     @id @default(autoincrement())
  menuId       Int     @map("menu_id")
  name         Json  // e.g. "Appetizers", "Drinks"
  displayOrder Int     @default(0) @map("display_order")
  
  // Relations
  menu     Menu      @relation(fields: [menuId], references: [id])
  products Product[]

  @@map("menu_sections")
}

model Product {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique @default(uuid()) @map("external_id") @db.Uuid
  merchantId  Int      @map("merchant_id")
  
  // Menu Organization
  sectionId   Int?     @map("section_id")
  
  name        Json
  description Json?
  price       Decimal? @db.Decimal(12, 2)
  currency    String?  @default("VND")
  sku         String?
  stock       Int?
  isActive    Boolean? @default(true) @map("is_active")
  metadata    Json?
  
  // Denormalized rating stats (updated via service when reviews change)
  averageRating   Float     @default(0) @map("average_rating")
  totalReviews    Int       @default(0) @map("total_reviews")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  merchant          Merchant          @relation(fields: [merchantId], references: [id])
  section           MenuSection?      @relation(fields: [sectionId], references: [id])
  
  variants          ProductVariant[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           Review[]

  @@map("products")
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  name      Json?
  price     Decimal? @db.Decimal(12, 2)
  stock     Int?
  metadata  Json?

  // Relations
  product Product @relation(fields: [productId], references: [id])

  @@map("product_variants")
}

// --- ORDER & CART ---

model Cart {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  merchantId  Int      @map("merchant_id")
  totalAmount Decimal? @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id])
  merchant  Merchant   @relation(fields: [merchantId], references: [id])
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int      @map("cart_id")
  productId Int      @map("product_id")
  variantId Int?     @map("variant_id")
  quantity  Int?
  price     Decimal? @db.Decimal(12, 2)
  total     Decimal? @db.Decimal(12, 2)
  metadata  Json?

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Courier {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  name            String?
  phone           String?
  status          String?  // 'available' | 'busy' | 'offline'
  vehicleType     String?  @map("vehicle_type") // 'bike' | 'motorbike' | 'car'
  currentLocation Json?    @map("current_location")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("couriers")
}

model Promotion {
  id             Int       @id @default(autoincrement())
  merchantId     Int?      @map("merchant_id")
  code           String?
  description    Json?
  discountType   String?   @map("discount_type") // 'percentage' | 'fixed'
  discountValue  Decimal?  @map("discount_value") @db.Decimal(12, 2)
  minOrderAmount Decimal?  @map("min_order_amount") @db.Decimal(12, 2)
  startAt        DateTime? @map("start_at")
  endAt          DateTime? @map("end_at")
  maxUses        Int?      @map("max_uses")
  metadata       Json?

  // Relations
  merchant Merchant? @relation(fields: [merchantId], references: [id])
  orders   Order[]

  @@map("promotions")
}

model ShippingFee {
  id          Int      @id @default(autoincrement())
  merchantId  Int      @map("merchant_id")
  minDistance Decimal? @map("min_distance")
  maxDistance Decimal? @map("max_distance")
  baseFee     Decimal? @map("base_fee") @db.Decimal(12, 2)
  feePerKm    Decimal? @map("fee_per_km") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@map("shipping_fees")
}

model Order {
  id              Int      @id @default(autoincrement())
  externalId      String   @unique @default(uuid()) @map("external_id") @db.Uuid
  userId          Int      @map("user_id")
  merchantId      Int      @map("merchant_id")
  totalAmount     Decimal? @map("total_amount") @db.Decimal(12, 2)
  currency        String?  @default("VND")
  status          String?  // 'pending' | 'confirmed' | 'preparing' | 'delivering' | 'completed' | 'cancelled'
  paymentStatus   String?  @map("payment_status") // 'pending' | 'paid' | 'failed' | 'refunded'
  deliveryAddress Json?    @map("delivery_address")
  courierId       Int?     @map("courier_id")
  shippingFee     Decimal? @map("shipping_fee")
  promotionId     Int?     @map("promotion_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id])
  merchant  Merchant   @relation(fields: [merchantId], references: [id])
  courier   Courier?   @relation(fields: [courierId], references: [id])
  promotion Promotion? @relation(fields: [promotionId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  productId Int      @map("product_id")
  variantId Int?     @map("variant_id")
  quantity  Int?
  price     Decimal? @db.Decimal(12, 2)
  total     Decimal? @db.Decimal(12, 2)
  metadata  Json?

  // Relations
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  productId  Int?     @map("product_id")
  merchantId Int?     @map("merchant_id")
  rating     Decimal?
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@map("reviews")
}

model OtpVerification {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("otp_verifications")
}
