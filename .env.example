# Local Environment
NODE_ENV=development
PORT=3000

# Database (Local Docker PostgreSQL)
DATABASE_URL="postgresql://admin:admin@localhost:5432/vhandelivery_db?schema=public"

# JWT / Auth
JWT_SECRET="local_secret_key_change_me"
JWT_EXPIRATION="1d"
JWT_REFRESH_SECRET="local_refresh_secret_key_change_me"
JWT_REFRESH_EXPIRATION="7d"
MAX_AGE_REFRESH_COOKIE=604800000  # 7 days in milliseconds

# Google OAuth 2.0

GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Default Frontend URL (fallback if Host header is missing)
# Development:
FRONTEND_URL="http://localhost:4200"
# Production:
# FRONTEND_URL="https://sharkbee.vn"


# AWS S3 / MinIO (Local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=admin123
AWS_BUCKET_NAME=vhan-media
AWS_ENDPOINT=http://localhost:9000
AWS_FORCE_PATH_STYLE=true


# Other Local Configs
LOG_LEVEL=debug

